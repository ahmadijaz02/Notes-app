<!DOCTYPE html>
<html>
<head>
  <title>Login - Notes App</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:1.2em;">
      <div style="background:linear-gradient(135deg,#6366f1 60%,#4338ca 100%);width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px #6366f133;margin-bottom:0.7em;">
        <span style="font-size:2.2em;color:#fff;">📝</span>
      </div>
      <h2 style="margin:0;font-size:2em;font-weight:800;letter-spacing:0.5px;color:#22223b;">Login</h2>
    </div>
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <form method="POST" action="/login" style="display:flex;flex-direction:column;gap:1em;align-items:stretch;">
      <label style="font-weight:500;margin-bottom:0.2em;">Username:</label>
  <input name="username" required autocomplete="username">
      <label style="font-weight:500;margin-bottom:0.2em;">Password:</label>
  <input name="password" type="password" required autocomplete="current-password">
      <button type="submit" style="width:100%;min-width:0;">Login</button>
    </form>
    <div style="text-align:center;margin-top:1em;">
      <a class="signup-link" href="/signup">Don't have an account? <b>Sign Up</b></a>
    </div>
  </div>
</body>
</html>
